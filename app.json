{
  "expo": {
    "name": "Baytak",
    "slug": "baytak-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#147672"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.baytak.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "نحتاج الوصول إلى الصور لتحديث صورة ملفك الشخصي.",
        "NSCameraUsageDescription": "نحتاج الكاميرا إن اخترت التقاط صورة لملفك الشخصي."
      }
    },
    "android": {
      "supportsRTL": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash.png",
        "backgroundColor": "#147672"
      },
      "package": "com.baytak.app"
    },
    "web": {
      "favicon": "./assets/images/splash.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "57a4c149-9f0b-4991-acec-d76ea203a1de"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول إلى الصور لتحديث صورة ملفك الشخصي.",
          "cameraPermission": "نحتاج الكاميرا إن اخترت التقاط صورة لملفك الشخصي."
        }
      ]
    ]
  }
}
